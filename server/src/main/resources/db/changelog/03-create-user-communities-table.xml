<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.1.xsd">

    <changeSet id="03" author="antigravity">
        <createTable tableName="user_communities">
            <column name="user_id" type="BIGINT">
                <constraints nullable="false" foreignKeyName="fk_uc_user_id" referencedTableName="users" referencedColumnNames="id"/>
            </column>
            <column name="community_id" type="BIGINT">
                <constraints nullable="false" foreignKeyName="fk_uc_community_id" referencedTableName="communities" referencedColumnNames="id"/>
            </column>
        </createTable>
        <addPrimaryKey tableName="user_communities" columnNames="user_id, community_id" constraintName="pk_user_communities"/>
    </changeSet>

</databaseChangeLog>
