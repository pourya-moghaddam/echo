<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
         http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.24.xsd">

    <changeSet id="06-create-votes" author="pourya">
        <addColumn tableName="posts">
            <column name="score" type="INT" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
        </addColumn>
        <addColumn tableName="comments">
            <column name="score" type="INT" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
        </addColumn>

        <createTable tableName="post_votes">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="user_id" type="BIGINT">
                <constraints nullable="false" foreignKeyName="fk_post_vote_user" referencedTableName="users" referencedColumnNames="id"/>
            </column>
            <column name="post_id" type="BIGINT">
                <constraints nullable="false" foreignKeyName="fk_post_vote_post" referencedTableName="posts" referencedColumnNames="id"/>
            </column>
            <column name="direction" type="VARCHAR(10)">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addUniqueConstraint tableName="post_votes" columnNames="user_id, post_id" constraintName="uk_post_vote_user_post"/>

        <createTable tableName="comment_votes">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="user_id" type="BIGINT">
                <constraints nullable="false" foreignKeyName="fk_comment_vote_user" referencedTableName="users" referencedColumnNames="id"/>
            </column>
            <column name="comment_id" type="BIGINT">
                <constraints nullable="false" foreignKeyName="fk_comment_vote_comment" referencedTableName="comments" referencedColumnNames="id"/>
            </column>
            <column name="direction" type="VARCHAR(10)">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addUniqueConstraint tableName="comment_votes" columnNames="user_id, comment_id" constraintName="uk_comment_vote_user_comment"/>
    </changeSet>

</databaseChangeLog>
